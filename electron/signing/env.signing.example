# Copy to repo root as `.env.signing` (gitignored) or export in your shell.
# CertManager: https://certmanager.certum.pl/certificate/108341876

# --- Certum SimplySign (typical — no .pfx) ---
# 1. Install SimplySign Desktop + unlock with TOTP so the cert appears in Windows store
# 2. Find thumbprint:
#      certutil -store My | findstr /i "Code Signing Thumbprint"
#    or PowerShell:
#      Get-ChildItem Cert:\CurrentUser\My | Where-Object { $_.HasPrivateKey } | Format-List Subject,Thumbprint
# 3. Set thumbprint (no spaces) and build on Windows:
#      npm run release:win

CERTUM_CERT_SHA1=
# CERTUM_CERT_SUBJECT=Acharya Annadata

# Certum RFC3161 timestamp (default if unset)
WIN_TIMESTAMP_URL=http://time.certum.pl

# Optional SimplySign automation (Windows only) — see signing/Connect-SimplySign.ps1
# CERTUM_OTP_URI=otpauth://totp/...
# CERTUM_USERID=
# CERTUM_EXE_PATH=C:\Program Files\Certum\SimplySign Desktop\SimplySignDesktop.exe

# --- Exportable PFX (uncommon for Certum; only if Certum gave you a .p12) ---
# WIN_CSC_LINK=C:\secure\pkc-codesign.pfx
# CSC_KEY_PASSWORD=

# --- macOS (Apple Developer ID — NOT Certum) ---
# CSC_LINK=file://path/to/DeveloperID.p12
# CSC_KEY_PASSWORD=
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_TEAM_ID=
